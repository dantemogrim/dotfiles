# shellcheck disable=all

alias a="alias"
alias c="clear"
alias e="printenv"
alias l_scripts="ls -lah $HOME/scripts/bash"
alias permit_me="chmod -R u+rwx"
alias permit_scripts="chmod -R u+rwx $HOME/scripts"
alias rel="source ~/.bashrc"
alias scripts="code $HOME/scripts"


{
	"container": {
		"prefix": "container",
		"body": [
			"@container ${1:name} ${2:condition} {",
			"  $0",
			"}"
		],
		"description": "Basic @container declaration"
	},
	"font-face": {
		"prefix": "ff",
		"body": [
			"@font-face {",
			"  font-family: '${1:fontName}';",
			"  src: url('${2:path/to/font.woff2}') format('woff2');",
			"}"
		],
		"description": "Basic @font-face declaration"
	},
	"media-query": {
		"prefix": "mq",
		"body": [
			"@media (${1:condition}) {",
			"  $0",
			"}"
		],
		"description": "Basic media query structure"
	},
	"prefer-color-scheme": {
		"prefix": "pcs",
		"body": [
			"@media (prefers-color-scheme: ${1|light,dark|}) {",
			"  $0",
			"}"
		],
		"description": "Media query for preferred color scheme"
	}
}
